generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id        String   @id
  email     String?
  quizData  Json?
  platform  String?
  referrer  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
}

model Event {
  id         String   @id @default(cuid())
  userId     String
  type       String
  payload    Json?
  timeOnStep Int?
  platform   String?
  referrer   String?
  createdAt  DateTime @default(now())
  session    Session  @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}
